    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const lead = item.json;\n  let score = 0;\n\n  const industry = (lead.industry || '').toLowerCase().trim();\n  const job_title = (lead.job_title || '').toLowerCase().trim();\n  const location = (lead.location || '').toLowerCase().trim();\n  const company = (lead.company || '').toLowerCase().trim();\n\n  // 1. Industry scoring\n  if (\n    industry.includes('insurance') ||\n    industry.includes('retail') ||\n    industry.includes('banking') ||\n    industry.includes('edtech') ||\n    industry.includes('education') ||\n    industry.includes('transportation')\n  ) {\n    score += 25;\n  } else {\n    score += 15;\n  }\n\n  // 2. Job title scoring\n  if (\n    job_title.includes('assistant manager') ||\n    job_title.includes('deputy manager') ||\n    job_title.includes('associate manager') ||\n    job_title.includes('hr manager') ||\n    job_title.includes('human resources manager')\n  ) {\n    score += 15;\n  } else if (\n    job_title.includes('senior manager') ||\n    job_title.includes('sales manager') ||\n    job_title === 'manager' ||\n    job_title.startsWith('manager ') ||\n    job_title.endsWith(' manager') ||\n    job_title.includes(' manager ')\n  ) {\n    score += 25;\n  } else {\n    score += 5;\n  }\n\n  // 3. Location scoring\n  if (\n    location.includes('ranchi') ||\n    location.includes('jamshedpur') ||\n    location.includes('dhanbad')\n  ) {\n    score += 25;\n  } else if (\n    location.includes('bokaro') ||\n    location.includes('hazaribagh') ||\n    location.includes('deoghar')\n  ) {\n    score += 15;\n  } else {\n    score += 5;\n  }\n\n  // 4. Company bonus\n  if (\n    company.includes('logistics') ||\n    company.includes('cargo') ||\n    company.includes('transport') ||\n    company.includes('carriers')\n  ) {\n    score += 10;\n  }\n\n  lead.icp_score = score;\n\n  return {\n    json: lead\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        16,
